    "lint:prettier": "prettier --check ./src",
    "test": "jest --config jest.config.ts"
  },
  "devDependencies": {
    "@gravity-ui/eslint-config": "^4.2.0",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@gravity-ui/tsconfig": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.0",
    "eslint": "^9.37.0",
    "jest": "^30.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "zod": "^4.1.12"
  }
