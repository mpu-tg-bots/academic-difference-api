{
  "name": "tgbot",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon",
    "lint": "run-p lint:ts lint:eslint lint:prettier",
    "lint:ts": "tsc --noEmit",
    "lint:eslint": "eslint",
    "lint:prettier": "prettier --check ./src",
    "test": "jest --config jest.config.ts",
    "gen:client": "npx @hey-api/openapi-ts -i http://localhost:8000/api/v1/schema/ -o src/generated/django-client"
  },
  "devDependencies": {
    "@gravity-ui/eslint-config": "^4.2.0",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@gravity-ui/tsconfig": "^1.0.0",
    "@hey-api/openapi-ts": "^0.85.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.0",
    "eslint": "^9.37.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@telegraf/session": "^2.0.0-beta.7",
    "express": "^5.1.0",
    "kysely": "^0.27.2",
    "telegraf": "^4.16.3",
    "zod": "^4.1.12"
  }
}
